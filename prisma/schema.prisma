generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  compositions Composition[]
  smokeLayouts SmokeLayout[]
}

model Composition {
  id        String   @id @default(cuid())
  name      String
  mapId     String
  agentIds  String[]
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmokeLayout {
  id        String   @id @default(cuid())
  name      String
  mapId     String
  isPublic  Boolean  @default(false)
  smokes    Json
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
